# Common settings (Linux arm)

include(linux.common)

[buildenv]
CC=/usr/bin/aarch64-linux-gnu-gcc-11
CXX=/usr/bin/aarch64-linux-gnu-g++-11
LD=/usr/bin/aarch64-linux-gnu-ld

[conf]
tools.build:compiler_executables={"c": "/usr/bin/aarch64-linux-gnu-gcc-11", "cpp": "/usr/bin/aarch64-linux-gnu-g++-11"}